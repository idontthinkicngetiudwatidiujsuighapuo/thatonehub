    if not targetPlayer or not targetPlayer.Character then return end

 local targetPartName = Flags["Target"] or "Head"
local part

if targetPartName == "Closest to mouse" then
    -- Find closest body part to mouse
    local mousePos = UserInputService:GetMouseLocation()
    local closestDist = math.huge
    
    for _, p in ipairs(targetPlayer.Character:GetChildren()) do
        if p:IsA("BasePart") then
            local sPos, onScreen = Camera:WorldToViewportPoint(p.Position)
            if onScreen then
                local dist = (Vector2.new(sPos.X, sPos.Y) - mousePos).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    part = p
                end
            end
        end
    end
    
    -- Fallback if no part found
    if not part then
        part = targetPlayer.Character:FindFirstChild("Head") or 
               targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    end
else
    -- Original behavior for Head/Torso
    part = targetPlayer.Character:FindFirstChild(targetPartName)
end
    
    -- Fallback if target part not found
    if not part then
        part = targetPlayer.Character:FindFirstChild("HumanoidRootPart") or 
               targetPlayer.Character:FindFirstChild("Head") or 
               targetPlayer.Character:FindFirstChild("Torso")
    end
    
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not part or not root then return end

    local aimPos = part.Position

    -- 1. PREDICTION
    local predictionScale = Flags["Prediction"] or 0
    if predictionScale > 0 then
        local velocity = root.AssemblyLinearVelocity
        local leadFactor = predictionScale / 50 
        aimPos = aimPos + (velocity * leadFactor)
    end

    -- 2. MOVEMENT CALCULATION
    local screenPos, onScreen = Camera:WorldToViewportPoint(aimPos)
    if not onScreen then return end

    local mouseLoc = UserInputService:GetMouseLocation()
    local moveVector = (Vector2.new(screenPos.X, screenPos.Y) - mouseLoc)

    local finalMoveX, finalMoveY
    
   if Flags["Hardlock"] then
    -- HARDLOCK: 2x Stronger (Double movement call per frame)
    finalMoveX = moveVector.X
    finalMoveY = moveVector.Y
    if mousemoverel then
        mousemoverel(finalMoveX, finalMoveY)
        mousemoverel(finalMoveX, finalMoveY)
    end
    return -- EXIT HERE for hardlock mode
end

-- NORMAL AIM (when hardlock is OFF)
local smoothness = math.max(1, Flags["Smoothness"] or 2)
finalMoveX = moveVector.X / smoothness
finalMoveY = moveVector.Y / smoothness
-- [[ NVHub | Smooth Shake Logic ]]

local shakeScale = Flags["Shake"] or 0

if shakeScale > 0 then
    -- We use (math.random() * 2 - 1) to get a decimal between -1 and 1
    -- Then multiply by shakeScale for the actual offset
    local offsetX = (math.random() * 2 - 1) * shakeScale
    local offsetY = (math.random() * 2 - 1) * shakeScale
    
    finalMoveX = finalMoveX + offsetX
    finalMoveY = finalMoveY + offsetY
end

    -- 4. EXECUTION
    if mousemoverel then
        mousemoverel(finalMoveX, finalMoveY)
    end
end)

