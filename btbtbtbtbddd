local function saveFlags()
    local toSave = {}
    for k, v in pairs(Flags) do
        if not dropHeaders[k] and (type(v) == "boolean" or type(v) == "number" or type(v) == "string") then
            toSave[k] = v
        end
    end
    local ok, content = pcall(function()
        return game:GetService("HttpService"):JSONEncode(toSave)
    end)
    if ok and content then 
        pcall(writefile, flagsFile, content) 
    end
end
