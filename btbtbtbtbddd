local function syncUI()
	local themeTweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
	for _, p in ipairs(Pillars) do
		TweenService:Create(p.Frame, themeTweenInfo, {BackgroundColor3 = Theme.Body}):Play()
		TweenService:Create(p.Header, themeTweenInfo, {BackgroundColor3 = Theme.Header}):Play()
		TweenService:Create(p.Fix, themeTweenInfo, {BackgroundColor3 = Theme.Header}):Play()
		TweenService:Create(p.Title, themeTweenInfo, {TextColor3 = Theme.Text}):Play()
	end
	for _, e in ipairs(Elements) do
		if e.Type == "Button" then
			local targetBtnCol = e.Active and Theme.Accent or Theme.Btn
			local targetTxtCol = (e.Active or Theme == Themes.Dark) and Color3.new(1,1,1) or Color3.new(0,0,0)
			TweenService:Create(e.Instance, themeTweenInfo, {BackgroundColor3 = targetBtnCol, TextColor3 = targetTxtCol}):Play()
		elseif e.Type == "Slider" then
			TweenService:Create(e.Label, themeTweenInfo, {TextColor3 = Theme.Text}):Play()
			TweenService:Create(e.ValLabel, themeTweenInfo, {TextColor3 = Theme.Text}):Play()
			TweenService:Create(e.Knob, themeTweenInfo, {BackgroundColor3 = Theme.Knob}):Play()
		elseif e.Type == "Textbox" then
			TweenService:Create(e.Instance, themeTweenInfo, {BackgroundColor3 = Theme.Btn, TextColor3 = Theme.Text}):Play()
		elseif e.Type == "Picker" then
			TweenService:Create(e.Label, themeTweenInfo, {TextColor3 = Theme.Text}):Play()
		end
	end
end



