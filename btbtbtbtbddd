local function createSnowEffect()
    local SnowGui = Instance.new("ScreenGui")
    SnowGui.Name = "SnowEffect"
    SnowGui.Parent = game:GetService("CoreGui")
    SnowGui.DisplayOrder = -999  -- MUCH lower than UI
    SnowGui.IgnoreGuiInset = true
    SnowGui.ResetOnSpawn = false
    SnowGui.Enabled = true
    SnowGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling  -- Important for layering
    
    local screenSize = game:GetService("GuiService"):GetScreenResolution()
    local snowflakes = {}
    local snowCount = 50  -- Reduced slightly for performance
    local lastCheck = tick()
    local isUIOpen = false
    
    -- Create frame to hold snow
    local snowFrame = Instance.new("Frame")
    snowFrame.Size = UDim2.new(1, 0, 1, 0)
    snowFrame.BackgroundTransparency = 1
    snowFrame.Parent = SnowGui
    snowFrame.ZIndex = -999  -- Negative ZIndex to ensure behind
    snowFrame.Active = false
    snowFrame.Selectable = false
    snowFrame.Visible = false
    
    -- Create snowflakes
    for i = 1, snowCount do
        local flake = Instance.new("Frame")
        flake.Size = UDim2.new(0, math.random(2, 5), 0, math.random(2, 5))
        flake.Position = UDim2.new(0, math.random(0, screenSize.X), 0, math.random(-100, screenSize.Y))
        flake.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        flake.BackgroundTransparency = math.random(40, 75) / 100
        flake.BorderSizePixel = 0
        flake.Parent = snowFrame
        flake.ZIndex = -999  -- Match parent ZIndex
        flake.Active = false
        flake.Selectable = false
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = flake
        
        -- Slower speeds
        snowflakes[i] = {
            frame = flake,
            speed = math.random(5, 15) / 10,  -- Slower
            drift = math.random(-8, 8) / 10,
            x = math.random(0, screenSize.X),
            y = math.random(-100, screenSize.Y),
        }
    end
    
    -- Check UI visibility efficiently
    local function checkUIVisible()
        for _, pillar in ipairs(Pillars) do
            if pillar.Frame and pillar.Frame.Visible then
                local pos = pillar.Frame.AbsolutePosition.Y
                if pos > 10 and pos < 1000 then  -- Visible range
                    return true
                end
            end
        end
        return false
    end
    
    -- Use RenderStepped with frame skipping (lighter than Heartbeat)
    local frame = 0
    game:GetService("RunService").RenderStepped:Connect(function()
        frame = frame + 1
        
        -- Check UI every 15 frames (less frequent)
        if frame % 15 == 0 then
            isUIOpen = checkUIVisible()
            snowFrame.Visible = isUIOpen
        end
        
        -- Only animate every 2 frames when visible
        if not isUIOpen or frame % 2 ~= 0 then return end
        
        local currentScreen = game:GetService("GuiService"):GetScreenResolution()
        
        for _, flake in ipairs(snowflakes) do
            flake.y = flake.y + flake.speed
            flake.x = flake.x + flake.drift
            
            if flake.y > currentScreen.Y + 20 then
                flake.y = math.random(-50, -10)
                flake.x = math.random(0, currentScreen.X)
            end
            
            if flake.x > currentScreen.X + 20 then
                flake.x = -20
            elseif flake.x < -20 then
                flake.x = currentScreen.X + 20
            end
            
            flake.frame.Position = UDim2.new(0, flake.x, 0, flake.y)
        end
    end)
    task.wait()

    return SnowGui
end

