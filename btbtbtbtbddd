local function getRealAssetId(assetId)
    local success, result = pcall(function()
        local model = InsertService:LoadLocalAsset("rbxassetid://" .. assetId)
        if model:IsA("Decal") then
            return model.Texture
        end
    end)
    -- If it fails or isn't a Decal, just return the original formatted string
    return success and result or "rbxassetid://" .. assetId
end

-- Function to apply sky using the ID from textbox
local function applySkyFromTextbox()
    -- Get ID from Flags table (from your textbox)
    local id = Flags["type Image Id"]
    
    if not id or id == "" then
        warn("❌ Please enter an Image ID in the textbox first!")
        return false
    end
    
    -- Clean up old skyboxes
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("Sky") then v:Destroy() end
    end
    
    -- Get the REAL asset ID
    local finalAsset = getRealAssetId(id)
    
    -- Create the sky
    local s = Instance.new("Sky")
    s.Name = "CustomSky"
    
    -- Apply the image to all 6 sides
    s.SkyboxBk = finalAsset
    s.SkyboxDn = finalAsset
    s.SkyboxFt = finalAsset
    s.SkyboxLf = finalAsset
    s.SkyboxRt = finalAsset
    s.SkyboxUp = finalAsset
    
    -- Remove sun/moon
    s.SunAngularSize = 0
    s.MoonAngularSize = 0
    
    s.Parent = Lighting
    
    -- Reset Ambient so the sky colors pop
    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    


    return true
end

