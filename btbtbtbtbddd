	box.Text = Flags[text] or ""
	box.TextColor3 = Theme.Text
	box.TextSize = 13 * uiScale
	box.TextXAlignment = Enum.TextXAlignment.Center -- FIX: Center the input text
	box.BorderSizePixel = 0
	box.ClearTextOnFocus = false
	
	-- Font Fix Logic
	local success = pcall(function()
		if typeof(Theme.Font) == "Font" then
			box.FontFace = Theme.Font
		else
			box.Font = Theme.Font or Enum.Font.SourceSans
		end
	end)
	if not success then box.Font = Enum.Font.SourceSans end

	table.insert(Elements, {Type = "Textbox", Instance = box})
	
	-- Optimized Save Logic (Debounce)
	local saveThread
	box:GetPropertyChangedSignal("Text"):Connect(function()
		Flags[text] = box.Text
		
		if saveThread then task.cancel(saveThread) end
		saveThread = task.delay(1, function()
			if saveFlags then saveFlags() end
		end)
	end)
	
	return container
end
