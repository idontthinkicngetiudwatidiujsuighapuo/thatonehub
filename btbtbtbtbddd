-- [[ Helper: Visibility Check - SIMPLE VERSION ]]
local function isVisible(part)
    if not Flags["Visible Check"] then return true end
    
    local char = LocalPlayer.Character
    if not char or not part then return false end
    
    -- Simple raycast from camera to target
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)
    
    local ray = Ray.new(origin, direction)
    local hit, position = workspace:FindPartOnRayWithIgnoreList(ray, {char, Camera})
    
    -- If nothing hit, it's visible
    if not hit then return true end
    
    -- If we hit the target or its parent, it's visible
    if hit:IsDescendantOf(part.Parent) then
        return true
    end
    
    return false
end

-- [[ Helper: Team Check ]]
local function isSameTeam(player)
    if not Flags["Team Check"] then return false end
    if LocalPlayer.Team ~= nil and player.Team ~= nil then
        return player.Team == LocalPlayer.Team
    end
    return LocalPlayer.TeamColor == player.TeamColor
end
-- [[ Helper: Get closest target inside FOV ]]
local function getClosestInFOV()
    local target = nil
    local shortestDistance = math.huge
    local targetSetting = Flags["Target"] or "Head"
    local fovLimit = Flags["Radius"] or 100
    local maxDistance = Flags["Max Studs Aimbot"] or 10000

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if isSameTeam(player) then continue end
        
        local char = player.Character
        if not char then continue end

        -- FIX: Determine a valid part to check for FOV/Distance
        -- If "Hole Body", we check the Torso or Head as a reference point
        local checkPart = char:FindFirstChild(targetSetting) or 
                          char:FindFirstChild("HumanoidRootPart") or 
                          char:FindFirstChild("Head") or 
                          char:FindFirstChild("UpperTorso")
        
        if not checkPart then continue end

        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end

        -- Distance Check
        local dist = (checkPart.Position - Camera.CFrame.Position).Magnitude
        if dist > maxDistance then continue end

        -- Visibility Check
        if not isVisible(checkPart) then continue end

        -- FOV Check
        local screenPos, onScreen = Camera:WorldToViewportPoint(checkPart.Position)
        if not onScreen then continue end

        local mouseLocation = UserInputService:GetMouseLocation()
        local distance = (Vector2.new(screenPos.X, screenPos.Y) - mouseLocation).Magnitude

        if distance < shortestDistance and distance <= fovLimit then
            shortestDistance = distance
            target = player
        end
    end
    return target
end
