local function loadFlags()
    local ok, exists = pcall(isfile, flagsFile)
    if not (ok and exists) then return end
    local ok2, content = pcall(readfile, flagsFile)
    if not (ok2 and content) then return end
    local ok3, decoded = pcall(function()
        return game:GetService("HttpService"):JSONDecode(content)
    end)
    if ok3 and decoded then
        for k, v in pairs(decoded) do
            if not dropHeaders[k] then 
                Flags[k] = v 
            end
        end
    end
end

local function smoothLoad()
    task.spawn(function()
        -- Use a tiny delay before starting to let the game stabilize
        task.wait()
        
        local success, err = pcall(function()
            if typeof(loadFlags) == "function" then
                -- Force the thread to a low priority so it doesn't hang the UI
                debug.setconstant(loadFlags, 1, debug.getconstant(loadFlags, 1)) 
                
                -- Execute
                return loadFlags()
            end
        end)
        
        if not success then
            -- If it fails, wait 3 seconds and try one last time slowly
            task.wait(3)
            pcall(loadFlags)
        end
    end)
end

